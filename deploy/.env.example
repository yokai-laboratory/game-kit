# ── deploy/.env ───────────────────────────────────────────────────────────────
# The single env file for the docker-compose stack. Copy to deploy/.env and fill in.
# `pnpm setup` (or the setup skill) populates the OAuth/TRON values for you.
#
#   cp deploy/.env.example deploy/.env

NODE_ENV=production

# ── Public address + TLS ──────────────────────────────────────────────────────
# Set DOMAIN to your hostname; Caddy auto-provisions a Let's Encrypt cert. Use "localhost" to test
# locally with a self-signed cert. ACME_EMAIL is where Let's Encrypt sends expiry notices.
DOMAIN=localhost
ACME_EMAIL=

# ── Persistence (Postgres + Redis) ────────────────────────────────────────────
# The compose stack runs Postgres + Redis for you and injects DATABASE_URL / REDIS_URL into the api,
# pointed at those in-network services -- so you normally leave the two URLs below unset here. Set
# POSTGRES_PASSWORD to something strong in production (compose passes it to the postgres service and
# into DATABASE_URL). The api listens on 8787 inside the container (Caddy proxies to api:8787).
API_PORT=8787
POSTGRES_PASSWORD=postgres

# Override ONLY if you point the api at an external Postgres/Redis instead of the bundled services
# (e.g. a managed database). When set, these win over the compose-injected in-network URLs.
# DATABASE_URL=postgres://user:pass@host:5432/game_kit
# REDIS_URL=redis://host:6379

# ── Sessions ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── App origins ───────────────────────────────────────────────────────────────
# In production web + /api share one origin behind Caddy, so WEB_ORIGIN is your https domain and the
# OAuth redirect goes through /api. Register OAUTH_REDIRECT_URI exactly in the TRON developer app.
WEB_ORIGIN=https://localhost
OAUTH_REDIRECT_URI=https://localhost/api/auth/callback

# ── Metatron OAuth client (from the TRON developer dashboard) ────────────
OAUTH_PROVIDER_NAME=metatron
OAUTH_AUTHORIZE_URL=https://api.metatron.gg/oauth/authorize
OAUTH_TOKEN_URL=https://api.metatron.gg/oauth/token
OAUTH_USERINFO_URL=https://api.metatron.gg/oauth/userinfo
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=openid profile payments:charge

# ── TRON server-to-server + payments ──────────────────────────────────────────
TRON_API_ORIGIN=https://api.metatron.gg
PAYMENT_CHAIN=ethereum-sepolia
PAYMENT_TOKEN=0x0000000000000000000000000000000000000000

# ── Build ─────────────────────────────────────────────────────────────────────
# Default npm registry (the SDK and everything else resolve from public npm).
NPM_CONFIG_REGISTRY=https://registry.npmjs.org/

LOG_LEVEL=info
