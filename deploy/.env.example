# ── deploy/.env ───────────────────────────────────────────────────────────────
# The single env file for the docker-compose stack. Copy to deploy/.env and fill in.
# `pnpm setup` (or the setup skill) populates the OAuth/TRON values for you.
#
#   cp deploy/.env.example deploy/.env

NODE_ENV=production

# ── Public address + TLS ──────────────────────────────────────────────────────
# Set DOMAIN to your hostname; Caddy auto-provisions a Let's Encrypt cert. Use "localhost" to test
# locally with a self-signed cert. ACME_EMAIL is where Let's Encrypt sends expiry notices.
DOMAIN=localhost
ACME_EMAIL=

# ── Persistence ───────────────────────────────────────────────────────────────
# Single SQLite file on the `sqlite_data` volume (compose sets SQLITE_PATH=/data/game-kit.sqlite).
# No external database. The api listens on 8787 inside the container (Caddy proxies to api:8787).
API_PORT=8787

# ── Scale-out (optional) ────────────────────────────────────────────────────────
# Leave REDIS_URL unset for the single-machine default (in-process realtime backplane + tick lease).
# Horizontal scale needs BOTH a shared db and the Redis seams re-enabled (see docker-compose.yml).
# REDIS_URL=redis://redis:6379

# ── Sessions ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── App origins ───────────────────────────────────────────────────────────────
# In production web + /api share one origin behind Caddy, so WEB_ORIGIN is your https domain and the
# OAuth redirect goes through /api. Register OAUTH_REDIRECT_URI exactly in the TRON developer app.
WEB_ORIGIN=https://localhost
OAUTH_REDIRECT_URI=https://localhost/api/auth/callback

# ── Metatron OAuth client (from the TRON developer dashboard) ────────────
OAUTH_PROVIDER_NAME=metatron
OAUTH_AUTHORIZE_URL=https://api.metatron.example/oauth/authorize
OAUTH_TOKEN_URL=https://api.metatron.example/oauth/token
OAUTH_USERINFO_URL=https://api.metatron.example/oauth/userinfo
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=openid profile payments:charge

# ── TRON server-to-server + payments ──────────────────────────────────────────
TRON_API_ORIGIN=https://api.metatron.example
PAYMENT_CHAIN=ethereum-sepolia
PAYMENT_TOKEN=0x0000000000000000000000000000000000000000

# ── Build ─────────────────────────────────────────────────────────────────────
# Default registry for everything except the @metatron scope (.npmrc pins that to Verdaccio).
NPM_CONFIG_REGISTRY=https://registry.npmjs.org/

LOG_LEVEL=info
