# ── deploy/.env ───────────────────────────────────────────────────────────────
# The single env file for the docker-compose stack. Copy to deploy/.env and fill in.
# `pnpm setup` (or the setup skill) populates the OAuth/TTG values for you.
#
#   cp deploy/.env.example deploy/.env

NODE_ENV=production

# ── Public address + TLS ──────────────────────────────────────────────────────
# Set DOMAIN to your hostname; Caddy auto-provisions a Let's Encrypt cert. Use "localhost" to test
# locally with a self-signed cert. ACME_EMAIL is where Let's Encrypt sends expiry notices.
DOMAIN=localhost
ACME_EMAIL=

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=gamekit
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=gamekit
# Host is the compose service name. Keep user/pass/db in sync with the three lines above.
DATABASE_URL=postgres://gamekit:change-me-strong-password@postgres:5432/gamekit

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Sessions ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# ── App origins ───────────────────────────────────────────────────────────────
# In production web + /api share one origin behind Caddy, so WEB_ORIGIN is your https domain and the
# OAuth redirect goes through /api. Register OAUTH_REDIRECT_URI exactly in the TTG developer app.
WEB_ORIGIN=https://localhost
OAUTH_REDIRECT_URI=https://localhost/api/auth/callback

# ── Titanium Games OAuth client (from the TTG developer dashboard) ────────────
OAUTH_PROVIDER_NAME=titanium-games
OAUTH_AUTHORIZE_URL=https://api.titaniumgames.example/oauth/authorize
OAUTH_TOKEN_URL=https://api.titaniumgames.example/oauth/token
OAUTH_USERINFO_URL=https://api.titaniumgames.example/oauth/userinfo
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=openid profile payments:charge

# ── TTG server-to-server + payments ──────────────────────────────────────────
TTG_API_ORIGIN=https://api.titaniumgames.example
PAYMENT_CHAIN=ethereum-sepolia
PAYMENT_TOKEN=0x0000000000000000000000000000000000000000

# ── Build ─────────────────────────────────────────────────────────────────────
# Default registry for everything except the @titanium-games scope (.npmrc pins that to Verdaccio).
NPM_CONFIG_REGISTRY=https://registry.npmjs.org/

LOG_LEVEL=info
