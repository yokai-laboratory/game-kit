# ── apps/api local-dev env ───────────────────────────────────────────────────
# Copy to apps/api/.env for local dev. For docker/VPS deploys, deploy/.env is the source of truth.
# `pnpm setup` (the setup skill) fills the OAuth/TTG values for you.

NODE_ENV=development
API_PORT=8787
WEB_ORIGIN=http://localhost:5273

# Shared state (docker-compose provides these locally on the default ports).
DATABASE_URL=postgres://gamekit:gamekit@localhost:5432/gamekit
REDIS_URL=redis://localhost:6379

# Sign-in/session signing. Generate with: openssl rand -hex 32
SESSION_SECRET=dev-only-insecure-secret-change-me

# ── Titanium Games OAuth client (from the TTG developer dashboard) ────────────
OAUTH_PROVIDER_NAME=titanium-games
OAUTH_AUTHORIZE_URL=https://api.titaniumgames.example/oauth/authorize
OAUTH_TOKEN_URL=https://api.titaniumgames.example/oauth/token
OAUTH_USERINFO_URL=https://api.titaniumgames.example/oauth/userinfo
OAUTH_CLIENT_ID=tg_dev_replace_me
OAUTH_CLIENT_SECRET=replace_me
OAUTH_REDIRECT_URI=http://localhost:8787/auth/callback
OAUTH_SCOPES=openid profile payments:charge

# ── TTG server-to-server + payments ──────────────────────────────────────────
TTG_API_ORIGIN=https://api.titaniumgames.example
# Chain id/name from TTG's enabled-chains catalog (e.g. anvil-local, ethereum-sepolia).
PAYMENT_CHAIN=anvil-local
# Token address: 0x000…0 for native ETH, or an ERC-20 address (assumed 18 decimals).
PAYMENT_TOKEN=0x0000000000000000000000000000000000000000

LOG_LEVEL=info
