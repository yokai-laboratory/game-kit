# ── apps/api local-dev env ───────────────────────────────────────────────────
# Copy to apps/api/.env for local dev. For docker/VPS deploys, deploy/.env is the source of truth.
# `pnpm setup` (the setup skill) fills the OAuth/TRON values for you.

NODE_ENV=development
API_PORT=8788
WEB_ORIGIN=http://localhost:5274

# Persistence: shared Postgres (the realtime engine serializes on row locks here). `dev.sh` does not
# start a database — bring your own and point this at it. The schema auto-bootstraps on first boot.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/game_kit

# OPTIONAL scale-out switch — leave unset for single-machine. Set it to a redis:// URL to enable the
# Redis-backed realtime backplane + tick lease (only needed when running multiple api replicas).
# REDIS_URL=redis://localhost:6379

# Sign-in/session signing. Generate with: openssl rand -hex 32
SESSION_SECRET=dev-only-insecure-secret-change-me

# ── Metatron OAuth client (from the TRON developer dashboard) ────────────
OAUTH_PROVIDER_NAME=metatron
OAUTH_AUTHORIZE_URL=https://api.metatron.gg/oauth/authorize
OAUTH_TOKEN_URL=https://api.metatron.gg/oauth/token
OAUTH_USERINFO_URL=https://api.metatron.gg/userinfo
OAUTH_CLIENT_ID=tg_dev_replace_me
OAUTH_CLIENT_SECRET=replace_me
OAUTH_REDIRECT_URI=http://localhost:8788/auth/callback
OAUTH_SCOPES=openid profile payments:charge

# ── TRON server-to-server + payments ──────────────────────────────────────────
TRON_API_ORIGIN=https://api.metatron.gg
# Chain id/name from TRON's enabled-chains catalog (e.g. anvil-local, ethereum-sepolia).
PAYMENT_CHAIN=anvil-local
# Token address: 0x000…0 for native ETH, or an ERC-20 address (assumed 18 decimals).
PAYMENT_TOKEN=0x0000000000000000000000000000000000000000

LOG_LEVEL=info
