# `@metatron/sdk` isn't on the public npm registry. It's served from the local Verdaccio
# registry that the metatron repo runs (its docker-compose `verdaccio` service). Only the
# `@metatron` scope is routed there; everything else resolves from the public registry.
#
# Prerequisite before `pnpm install` can resolve the SDK (the setup skill automates this):
#   in the metatron repo:  docker compose up -d verdaccio
#                                pnpm build --filter @metatron/sdk
#                                cd packages/sdk && pnpm publish --registry http://localhost:4873 --no-git-checks
#
# If you host the SDK on a different registry (your own Verdaccio, GitHub Packages, a private npm
# org), point the scope below at it instead.
@metatron:registry=http://localhost:4873
