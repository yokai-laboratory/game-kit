{
    "name": "game-kit",
    "private": true,
    "packageManager": "pnpm@11.1.2",
    "description": "Full-stack web3 game template built on the Metatron (TRON) payment + identity rails. Ships a coin-flip duel example you swap out for your own game.",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "turbo run dev --parallel",
        "build": "turbo run build",
        "typecheck": "turbo run typecheck",
        "lint": "turbo run lint",
        "setup": "tsx scripts/setup.ts"
    },
    "devDependencies": {
        "@types/node": "26.0.0",
        "tsx": "4.22.4",
        "turbo": "2.9.18",
        "typescript": "6.0.3"
    }
}
